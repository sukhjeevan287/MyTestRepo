{
	"name": "AddidingTImestamp",
	"properties": {
		"type": "Flowlet",
		"typeProperties": {
			"sources": [],
			"sinks": [],
			"transformations": [
				{
					"name": "derivedColumn1"
				},
				{
					"name": "input1"
				},
				{
					"name": "output1"
				}
			],
			"scriptLines": [
				"input(output(",
				"          EId as integer,",
				"          Name as string,",
				"          DepartmentID as integer",
				"     ),",
				"     order: 0,",
				"     allowSchemaDrift: true) ~> input1",
				"input1 derive(DateTime = currentTimestamp()) ~> derivedColumn1",
				"derivedColumn1 output(mapColumn(",
				"          EId,",
				"          Name,",
				"          DepartmentID,",
				"          DateTime",
				"     )) ~> output1"
			]
		}
	}
}