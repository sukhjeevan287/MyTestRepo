						"value": "[parameters('LS_ADLS_Source_New_properties_typeProperties_url')]"
					},
					"LS_RestAPI_properties_typeProperties_url": {
						"value": "[parameters('LS_RestAPI_properties_typeProperties_url')]"
					},
					"LS_SQL_Source_New_properties_typeProperties_server": {
						"value": "[parameters('LS_SQL_Source_New_properties_typeProperties_server')]"
					},
					"LS_SQL_Source_New_properties_typeProperties_database": {
						"value": "[parameters('LS_SQL_Source_New_properties_typeProperties_database')]"
					},
					"LS_SQL_Source_New_properties_typeProperties_userName": {
						"value": "[parameters('LS_SQL_Source_New_properties_typeProperties_userName')]"
					},
					"LS_LocalSQLServer_properties_typeProperties_server": {
						"value": "[parameters('LS_LocalSQLServer_properties_typeProperties_server')]"
					},
					"LS_LocalSQLServer_properties_typeProperties_database": {
						"value": "[parameters('LS_LocalSQLServer_properties_typeProperties_database')]"
					},
					"LS_LocalSQLServer_properties_typeProperties_userName": {
						"value": "[parameters('LS_LocalSQLServer_properties_typeProperties_userName')]"
					}
				}
			},
			"dependsOn": []
		},
		{
			"name": "mydevdatafactorydatagen_ArmTemplate_1",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_1.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					}
				}
			},
			"dependsOn": [
				"[resourceId('Microsoft.Resources/deployments', 'mydevdatafactorydatagen_ArmTemplate_0')]"
			]
		}
